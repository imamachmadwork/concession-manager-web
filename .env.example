# Copy to .env and adjust. All variables are optional — sane defaults are
# baked into pyproject.toml / clients/api_client.py so the suite runs
# out of the box with none of this set.

# Frontend base URL for tests/e2e. Defaults to https://concessions.roamstay.com
# (see pyproject.toml's [tool.pytest.ini_options] base_url).
PYTEST_BASE_URL=https://concessions.roamstay.com

# Backend base URL for tests/api. Defaults to https://jsonplaceholder.typicode.com
# (see clients/api_client.py), the template's placeholder API — swap this for
# the app's actual API host once known.
API_BASE_URL=https://jsonplaceholder.typicode.com

# Credentials for the authenticated-session pattern (see tests/e2e/conftest.py
# and tests/api/conftest.py) — only needed once sign-in is wired up.
DEFAULT_EMAIL=your-email@example.com
DEFAULT_PASSWORD=your-password
